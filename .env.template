# Required
ADMIN_API_KEY=change-this-strong-admin-key

# Optional request/body limits
JSON_BODY_LIMIT=1mb
FORM_BODY_LIMIT=1mb
MAX_UPLOAD_BYTES=524288000

# Optional rate limit (slice endpoints)
SLICE_RATE_LIMIT_WINDOW_MS=60000
SLICE_RATE_LIMIT_MAX_REQUESTS=3

# Optional slice queue limits
MAX_CONCURRENT_SLICES=1
MAX_SLICE_QUEUE_LENGTH=100
MAX_SLICE_QUEUE_WAIT_MS=300000

# Optional ZIP guard limits
MAX_ZIP_ENTRIES=200
MAX_ZIP_UNCOMPRESSED_BYTES=524288000

# Optional debug logs
DEBUG_COMMAND_LOGS=false
